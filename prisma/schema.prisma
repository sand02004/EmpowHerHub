generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  WOMAN
  MENTOR
  SPONSOR
  ADMIN
}

enum AccountStatus {
  PENDING
  APPROVED
  REJECTED
  IN_REVIEW
}

enum MentorshipType {
  ONLINE
  PHYSICAL
  BOTH
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id               String        @id @default(uuid())
  email            String        @unique
  passwordHash     String
  firstName        String
  lastName         String
  phoneNumber      String?
  role             Role          @default(WOMAN)
  accountStatus    AccountStatus @default(PENDING)
  organizationName String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  womenProfile   WomenProfile?
  mentorProfile  MentorProfile?
  sponsorProfile SponsorProfile?
  adminProfile   AdminProfile?

  opportunityApplications  OpportunityApplication[] @relation("ApplicantApplications")
  opportunities            Opportunity[]            @relation("SponsorOpportunities")
  mentorshipAppsAsMentee   MentorshipApplication[]  @relation("MenteeApplications")
  mentorshipAppsAsMentor   MentorshipApplication[]  @relation("MentorApplications")
  mentorshipPrograms       MentorshipProgram[]      @relation("MentorPrograms")
  activeMentorshipsMentee  Mentorship[]             @relation("MenteeMentorships")
  activeMentorshipsMentor  Mentorship[]             @relation("MentorMentorships")
  testsTaken               UserTest[]
  conversationsAsUser1     Conversation[]           @relation("User1Conversations")
  conversationsAsUser2     Conversation[]           @relation("User2Conversations")
  messagesSent             Message[]
  filesUploaded            FileUpload[]             @relation("UploaderFiles")
}

model WomenProfile {
  id                    String    @id @default(uuid())
  userId                String    @unique
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dateOfBirth           DateTime?
  profileImageId        String?   @unique
  profileImage          FileUpload? @relation("WomenProfileImage", fields: [profileImageId], references: [id])
  personalDetails       String?   @db.Text
  country               String?
  city                  String?
  educationLevel        String?
  areaOfInterest        String?
  careerGoals           String?   @db.Text
  skills                String[]
  skillsToDevelop       String[]
  preferredMentorGender String?
  nationalIdFileId      String?   @unique
  nationalIdFile        FileUpload? @relation("WomenNationalId", fields: [nationalIdFileId], references: [id])
}

model MentorProfile {
  id                     String    @id @default(uuid())
  userId                 String    @unique
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobTitle               String?
  company                String?
  yearsExperience        Int       @default(0)
  industry               String?
  education              String?
  professionalBackground String?   @db.Text
  expertiseAreas         String[]
  mentorshipTopics       String[]
  mentorshipExperience   String?   @db.Text
  mentorshipType         MentorshipType?
  availableHours         String?
  profileImageId         String?   @unique
  profileImage           FileUpload? @relation("MentorProfileImage", fields: [profileImageId], references: [id])
  certificateFileId      String?   @unique
  certificateFile        FileUpload? @relation("MentorCertificate", fields: [certificateFileId], references: [id])
  nationalIdFileId       String?   @unique
  nationalIdFile         FileUpload? @relation("MentorNationalId", fields: [nationalIdFileId], references: [id])
}

model SponsorProfile {
  id               String  @id @default(uuid())
  userId           String  @unique
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationName String
  description      String? @db.Text
  industry         String?
  website          String?
  logoFileId       String? @unique
  logoFile         FileUpload? @relation("SponsorLogo", fields: [logoFileId], references: [id])
}

model AdminProfile {
  id         String  @id @default(uuid())
  userId     String  @unique
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  department String?
}

model FileUpload {
  id            String   @id @default(uuid())
  uploaderId    String
  uploader      User     @relation("UploaderFiles", fields: [uploaderId], references: [id])
  originalName  String
  mimeType      String
  fileUrl       String
  fileSize      Int
  createdAt     DateTime @default(now())

  womenProfileImage   WomenProfile? @relation("WomenProfileImage")
  womenNationalId    WomenProfile? @relation("WomenNationalId")
  mentorProfileImage  MentorProfile? @relation("MentorProfileImage")
  mentorCertificate   MentorProfile? @relation("MentorCertificate")
  mentorNationalId    MentorProfile? @relation("MentorNationalId")
  sponsorLogo         SponsorProfile? @relation("SponsorLogo")
  applicationResume   OpportunityApplication? @relation("ApplicationResume")
}

model Opportunity {
  id           String                   @id @default(uuid())
  title        String
  type         String
  description  String                   @db.Text
  requirements String                   @db.Text
  deadline     DateTime
  sponsorId    String
  sponsor      User                     @relation("SponsorOpportunities", fields: [sponsorId], references: [id])
  applications OpportunityApplication[]
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
}

model OpportunityApplication {
  id            String            @id @default(uuid())
  opportunityId String
  opportunity   Opportunity       @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  userId        String
  user          User              @relation("ApplicantApplications", fields: [userId], references: [id], onDelete: Cascade)
  coverLetter   String            @db.Text
  resumeFileId  String?           @unique
  resumeFile    FileUpload?       @relation("ApplicationResume", fields: [resumeFileId], references: [id])
  status        ApplicationStatus @default(PENDING)
  createdAt     DateTime          @default(now())
}

model MentorshipProgram {
  id           String                  @id @default(uuid())
  mentorId     String
  mentor       User                    @relation("MentorPrograms", fields: [mentorId], references: [id], onDelete: Cascade)
  title        String
  description  String                  @db.Text
  slots        Int                     @default(5)
  duration     String?
  status       String                  @default("OPEN")
  applications MentorshipApplication[]
  mentorships  Mentorship[]
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
}

model MentorshipApplication {
  id         String             @id @default(uuid())
  programId  String?
  program    MentorshipProgram? @relation(fields: [programId], references: [id], onDelete: SetNull)
  mentorId   String
  mentor     User               @relation("MentorApplications", fields: [mentorId], references: [id], onDelete: Cascade)
  menteeId   String
  mentee     User               @relation("MenteeApplications", fields: [menteeId], references: [id], onDelete: Cascade)
  message    String             @db.Text
  status     ApplicationStatus  @default(PENDING)
  createdAt  DateTime           @default(now())
}

model Mentorship {
  id        String             @id @default(uuid())
  programId String?
  program   MentorshipProgram? @relation(fields: [programId], references: [id], onDelete: SetNull)
  mentorId  String
  mentor    User               @relation("MentorMentorships", fields: [mentorId], references: [id], onDelete: Cascade)
  menteeId  String
  mentee     User               @relation("MenteeMentorships", fields: [menteeId], references: [id], onDelete: Cascade)
  startDate DateTime           @default(now())
}

model Test {
  id           String     @id @default(uuid())
  title        String
  description  String?    @db.Text
  passingScore Int        @default(60)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  questions    Question[]
  userTests    UserTest[]
}

model Question {
  id      String         @id @default(uuid())
  testId  String
  test    Test           @relation(fields: [testId], references: [id], onDelete: Cascade)
  content String         @db.Text
  options AnswerOption[]
}

model AnswerOption {
  id         String   @id @default(uuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  content    String
  isCorrect  Boolean  @default(false)
}

model UserTest {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  testId      String
  test        Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  score       Float?
  passed      Boolean?
  completedAt DateTime @default(now())
}

model Conversation {
  id        String    @id @default(uuid())
  user1Id   String
  user1     User      @relation("User1Conversations", fields: [user1Id], references: [id])
  user2Id   String
  user2     User      @relation("User2Conversations", fields: [user2Id], references: [id])
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([user1Id, user2Id])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  content        String       @db.Text
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
}
