// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // We are telling Prisma we will use PostgreSQL
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  WOMAN
  MENTOR
  SPONSOR
  ADMIN
}

enum AccountStatus {
  PENDING
  APPROVED
  REJECTED
  IN_REVIEW
}

enum MentorshipType {
  ONLINE
  PHYSICAL
  BOTH
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

// ============================================================
// CORE USER MODEL
// ============================================================

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  firstName     String
  lastName      String
  phoneNumber   String?
  role          Role     @default(WOMAN)
  accountStatus AccountStatus @default(PENDING) // Controlled by Admin
  
  // Relations
  womenProfile   WomenProfile?
  mentorProfile  MentorProfile?
  sponsorProfile SponsorProfile?

  userTests      UserTest[]
  opportunities  Opportunity[] 
  
  mentorshipApplicationsAsMentee MentorshipApplication[] @relation("MenteeApplications")
  mentorshipApplicationsAsMentor MentorshipApplication[] @relation("MentorApplications")
  opportunityApplications        OpportunityApplication[]

  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============================================================
// ROLE PROFILES
// ============================================================

model WomenProfile {
  id                    String   @id @default(uuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  skills                String[]

  dateOfBirth           DateTime?
  profileImage          String?
  personalDetails       String?  @db.Text

  country               String?
  city                  String?
  educationLevel        String?
  areaOfInterest        String?  // Technology, Business, Leadership

  careerGoals           String?  @db.Text
  skillsToDevelop       String[]

  preferredMentorGender String?
  nationalIdUrl         String?
}

model MentorProfile {
  id                    String   @id @default(uuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  professionalBackgroundDescription String  @db.Text
  mentorshipCertificateUrl          String?
  yearsExperience                   Int

  jobTitle              String?
  company               String?
  industry              String?
  education             String?

  expertiseAreas        String[]
  mentorshipTopics      String[]

  mentorshipExperience  String?  @db.Text
  availableHours        String?

  profileImage          String?
  nationalIdUrl         String?

  mentorshipType        MentorshipType?
}

model SponsorProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationName  String
  industry          String?
  website           String?
  description       String?  @db.Text
  logoUrl           String?
}

// ============================================================
// SKILLS ASSESSMENT SYSTEM
// ============================================================

model Test {
  id           String     @id @default(uuid())
  title        String
  description  String?    @db.Text
  passingScore Int        @default(60)

  questions    Question[]
  userTests    UserTest[]

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Question {
  id            String        @id @default(uuid())
  testId        String
  test          Test          @relation(fields: [testId], references: [id], onDelete: Cascade)

  content       String        @db.Text

  answerOptions AnswerOption[]
  userAnswers   UserAnswer[]
}

model AnswerOption {
  id           String     @id @default(uuid())
  questionId   String
  question     Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)

  content      String
  isCorrect    Boolean    @default(false)

  userAnswers  UserAnswer[]
}

model UserTest {
  id           String     @id @default(uuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  testId       String
  test         Test       @relation(fields: [testId], references: [id], onDelete: Cascade)

  score        Float?
  passed       Boolean?
  completedAt  DateTime?

  answers      UserAnswer[]

  @@unique([userId, testId])
}

model UserAnswer {
  id             String        @id @default(uuid())

  userTestId     String
  userTest       UserTest      @relation(fields: [userTestId], references: [id], onDelete: Cascade)

  questionId     String
  question       Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)

  answerOptionId String
  answerOption   AnswerOption  @relation(fields: [answerOptionId], references: [id], onDelete: Cascade)
}

// ============================================================
// MENTORSHIP & OPPORTUNITIES
// ============================================================

model MentorshipApplication {
  id          String   @id @default(uuid())
  
  menteeId    String
  mentee      User     @relation("MenteeApplications", fields: [menteeId], references: [id])
  
  mentorId    String
  mentor      User     @relation("MentorApplications", fields: [mentorId], references: [id])
  
  status      ApplicationStatus @default(PENDING)
  message     String?  @db.Text
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Opportunity {
  id          String   @id @default(uuid())
  
  sponsorId   String
  sponsor     User     @relation(fields: [sponsorId], references: [id])
  
  title       String
  description String   @db.Text
  type        String   // Internship, Scholarship, Training, Grant
  location    String?
  isRemote    Boolean  @default(false)
  requirements String? @db.Text
  deadline    DateTime?
  
  applications OpportunityApplication[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OpportunityApplication {
  id            String   @id @default(uuid())
  
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  
  applicantId   String
  applicant     User     @relation(fields: [applicantId], references: [id])
  
  status        ApplicationStatus @default(PENDING)
  coverLetter   String?  @db.Text
  resumeUrl     String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============================================================
// MESSAGING CORE
// ============================================================

model Message {
  id          String   @id @default(uuid())
  
  senderId    String
  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
  
  receiverId  String
  receiver    User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  
  content     String   @db.Text
  isRead      Boolean  @default(false)
  
  createdAt   DateTime @default(now())
}
